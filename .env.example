# ── Backend ──────────────────────────────────────────────────────────────────
# Copy to backend/.env before running the server

PORT=3000
NODE_ENV=development

# Absolute path to the SQLite database file (defaults to backend/data/crm.db)
# DB_PATH=/absolute/path/to/crm.db

# Allowed CORS origins (comma-separated). Leave blank to allow all origins.
# CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Copy to frontend/.env.local before running the dev server

# The backend API base URL used by Vite's dev proxy
VITE_API_URL=http://localhost:3000
